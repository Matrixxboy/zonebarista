  <!-- ═══════════════════════════════════
       PROCESSING METHODS
  ═══════════════════════════════════ -->
  <processing_methods>

    <method id="washed">
      <name>Washed (Wet)</name>
      <steps>Depulp → Ferment in water tank (12–72h) → Wash → Dry on raised beds</steps>
      <cup_impact>Clean, bright, terroir-forward; lower body than natural</cup_impact>
      <acidity>High, pronounced</acidity>
      <body>Medium</body>
      <ferment_risk>Low (mucilage removed before drying)</ferment_risk>
      <common_regions>Ethiopia (Yirgacheffe), Colombia, Kenya, Central America</common_regions>
    </method>

    <method id="natural">
      <name>Natural (Dry/Unwashed)</name>
      <steps>Dry whole cherry on raised beds 3–6 weeks → Mill</steps>
      <cup_impact>Fruity, wine-like, heavy body, complex; higher ferment risk</cup_impact>
      <acidity>Low–medium</acidity>
      <body>Heavy, syrupy</body>
      <ferment_risk>High (moisture in cherry over long drying)</ferment_risk>
      <common_regions>Ethiopia (Harrar), Brazil, some Colombia</common_regions>
    </method>

    <method id="honey">
      <name>Honey / Pulped Natural</name>
      <steps>Depulp → Dry with mucilage (parchment) remaining → Mill</steps>
      <variants>Yellow (little mucilage), Red (medium), Black (maximum)</variants>
      <cup_impact>Between washed and natural; sweet, fruity, balanced</cup_impact>
      <common_regions>Costa Rica, Brazil, Colombia (growing), El Salvador</common_regions>
    </method>

    <method id="anaerobic">
      <name>Anaerobic Fermentation</name>
      <steps>Cherries sealed in tank → controlled fermentation → Then washed or natural drying</steps>
      <cup_impact>Intense fruit, complex, novel flavours; wine-like, tropical, fermented notes</cup_impact>
      <origin>Competition coffee; specialty innovation; 2010s+</origin>
    </method>

    <method id="wet_hulled">
      <name>Wet-Hulled (Giling Basah)</name>
      <steps>Partial wet process → Hull while still wet → Dry at high moisture</steps>
      <cup_impact>Heavy body, low acidity, earthy, cedar, tobacco</cup_impact>
      <common_regions>Indonesia (Sumatra, Sulawesi, Flores)</common_regions>
    </method>

    <method id="monsooned">
      <name>Monsooned (India-specific)</name>
      <steps>Green beans exposed to monsoon winds in open warehouses 12–16 weeks</steps>
      <cup_impact>Near-zero acidity, very heavy body, earthy, woody, tobacco, spice</cup_impact>
      <common_regions>Malabar Coast, Karnataka, Kerala (India)</common_regions>
    </method>

  </processing_methods>

