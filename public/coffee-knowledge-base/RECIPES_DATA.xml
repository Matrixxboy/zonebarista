  <roast_reference>

    <roast_levels>
      <level name="Very Light" agtron_min="85" agtron_max="100" drop_temp_c="193–196" notes="Raw/grassy notes possible; origin-forward"/>
      <level name="Light" agtron_min="75" agtron_max="84" drop_temp_c="196–205" notes="Floral, fruity, bright; specialty standard"/>
      <level name="Medium-Light" agtron_min="65" agtron_max="74" drop_temp_c="205–210" notes="Balanced; some caramel; origin + roast"/>
      <level name="Medium" agtron_min="55" agtron_max="64" drop_temp_c="210–218" notes="Classic balance; caramel, chocolate"/>
      <level name="Medium-Dark" agtron_min="45" agtron_max="54" drop_temp_c="218–225" notes="Bittersweet; low acidity; espresso classic"/>
      <level name="Dark" agtron_min="25" agtron_max="44" drop_temp_c="225–240" notes="Roast dominant; smoky; bold"/>
      <level name="Very Dark / French" agtron_min="0" agtron_max="24" drop_temp_c="240+" notes="Carbonised; bitter; oils visible"/>
    </roast_levels>

    <key_temperatures>
