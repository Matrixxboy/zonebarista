    <profile id="wtr-004" name="Espresso Optimised (1L RO water)">
      <ingredient name="Magnesium Sulfate" formula="MgSO4·7H2O" amount_g="0.80"/>
      <ingredient name="Calcium Chloride" formula="CaCl2" amount_g="0.50"/>
      <ingredient name="Sodium Bicarbonate" formula="NaHCO3" amount_g="0.25"/>
      <resulting_TDS unit="mg_per_L">~200</resulting_TDS>
      <resulting_Mg unit="mg_per_L">~39</resulting_Mg>
      <resulting_Ca unit="mg_per_L">~18</resulting_Ca>
      <use>Higher mineral for espresso body and crema</use>
    </profile>

  </water_profiles>

