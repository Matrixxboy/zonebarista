      <point name="First crack full" temp_c="200–205" description="Rapid cracking"/>
      <point name="Development zone" temp_c="200–220" description="Post-crack; DTR target 20–25%"/>
      <point name="Second crack onset" temp_c="224–227" description="Continuous cracking; oily surface"/>
      <point name="Second crack full" temp_c="228–232" description="Dark roast; pyrolysis dominant"/>
    </key_temperatures>

