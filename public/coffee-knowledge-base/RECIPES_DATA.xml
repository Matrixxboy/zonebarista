  <!-- ═══════════════════════════════════
       ESPRESSO RECIPES
  ═══════════════════════════════════ -->
  <espresso_recipes>

    <recipe id="esp-001" name="Standard Specialty Espresso">
      <dose unit="g">18</dose>
      <yield unit="g">36</yield>
      <ratio>1:2</ratio>
      <time unit="seconds">25–32</time>
      <temperature unit="celsius">93</temperature>
      <pressure unit="bar">9</pressure>
      <EY_target unit="percent">18–22</EY_target>
      <TDS_target unit="percent">8–12</TDS_target>
      <style>Standard double espresso</style>
      <notes>SCA and WBC baseline. Adjust grind to hit time window.</notes>
    </recipe>

    <recipe id="esp-002" name="Ristretto">
      <dose unit="g">18</dose>
      <yield unit="g">22–27</yield>
      <ratio>1:1.2–1.5</ratio>
      <time unit="seconds">20–28</time>
      <temperature unit="celsius">92</temperature>
      <pressure unit="bar">9</pressure>
      <notes>Short, concentrated. Sweeter, less bitter than standard. Used for flat whites and milk drinks.</notes>
    </recipe>

    <recipe id="esp-003" name="Lungo">
      <dose unit="g">18</dose>
      <yield unit="g">54–72</yield>
      <ratio>1:3–4</ratio>
      <time unit="seconds">35–50</time>
      <temperature unit="celsius">94</temperature>
      <pressure unit="bar">9</pressure>
      <notes>Long pull. More bitter than standard. Less common in specialty.</notes>
    </recipe>

    <recipe id="esp-004" name="Turbo Shot">
      <dose unit="g">18</dose>
      <yield unit="g">45–60</yield>
      <ratio>1:2.5–3</ratio>
      <time unit="seconds">10–15</time>
      <temperature unit="celsius">93</temperature>
      <pressure unit="bar">9</pressure>
      <grind_note>Much coarser than standard — counter-intuitive</grind_note>
      <notes>Fast, high-flow, coarse grind. Clean, bright, filter-like espresso. Competition-popular.</notes>
    </recipe>

    <recipe id="esp-005" name="Competition Profile Espresso (Declining Pressure)">
      <dose unit="g">20</dose>
      <yield unit="g">42–46</yield>
      <ratio>1:2.1–2.3</ratio>
      <time unit="seconds">28–36</time>
      <temperature unit="celsius">94</temperature>
      <pressure_profile>
        <phase name="pre-infusion">3–4 bar for 8–12s</phase>
        <phase name="ramp">Ramp to 9 bar over 5s</phase>
        <phase name="decline">Decline from 9 to 5–6 bar over 15s</phase>
      </pressure_profile>
      <notes>Used by WBC finalists. Reduces harsh extraction at end of shot.</notes>
    </recipe>

  </espresso_recipes>

  <!-- ═══════════════════════════════════
       MILK DRINK RECIPES
  ═══════════════════════════════════ -->
  <milk_drink_recipes>

    <recipe id="mlk-001" name="Flat White">
      <espresso>Double ristretto (18g / 22–27g yield)</espresso>
      <milk unit="mL">100–120</milk>
      <cup_size unit="oz">5–6</cup_size>
      <milk_texture>Microfoam — silky, minimal stretch</milk_texture>
      <temperature unit="celsius">60–65</temperature>
      <latte_art>Heart or simple rosetta</latte_art>
      <origin>Australia/New Zealand</origin>
      <notes>Strong espresso-to-milk ratio. Espresso flavour dominant. Full microfoam texture.</notes>
    </recipe>

    <recipe id="mlk-002" name="Latte (Flat/Café Latte)">
      <espresso>Double espresso (18g / 36g yield)</espresso>
      <milk unit="mL">180–240</milk>
      <cup_size unit="oz">8–12</cup_size>
      <milk_texture>Silky microfoam — moderate stretch</milk_texture>
      <temperature unit="celsius">60–65</temperature>
      <latte_art>Rosetta, tulip, or heart</latte_art>
      <notes>Most popular café drink globally. Balanced espresso + milk. Smooth and approachable.</notes>
    </recipe>

    <recipe id="mlk-003" name="Cappuccino">
      <espresso>Double espresso (18g / 36g yield)</espresso>
      <milk unit="mL">80–100</milk>
      <cup_size unit="oz">5–6</cup_size>
      <milk_texture>Thick microfoam — maximum stretch (40–50% volume increase)</milk_texture>
      <temperature unit="celsius">60–65</temperature>
      <foam_to_liquid_ratio>1:1 foam to steamed milk</foam_to_liquid_ratio>
      <notes>Traditional Italian: equal thirds espresso, steamed milk, foam. Modern specialty: all microfoam.</notes>
    </recipe>

    <recipe id="mlk-004" name="Cortado">
      <espresso>Double espresso (18g / 36g yield)</espresso>
      <milk unit="mL">30–40</milk>
      <cup_size unit="oz">3–4</cup_size>
      <milk_texture>Minimal stretch — just to cut espresso bitterness</milk_texture>
      <notes>Spanish origin. "Cortado" = cut. Equal parts espresso and milk. Bold, minimal.</notes>
    </recipe>

    <recipe id="mlk-005" name="Macchiato (Espresso)">
      <espresso>Double espresso (18g / 36g yield)</espresso>
      <milk unit="mL">10–15</milk>
      <cup_size unit="oz">3</cup_size>
      <milk_texture>Dollop of microfoam on top</milk_texture>
      <notes>"Macchiato" = stained. Espresso stained with small amount of foam.</notes>
    </recipe>

    <recipe id="mlk-006" name="Piccolo Latte">
      <espresso>Single ristretto (18g / 22g yield)</espresso>
      <milk unit="mL">80–90</milk>
      <cup_size unit="oz">3.5–4</cup_size>
      <milk_texture>Silky microfoam</milk_texture>
      <notes>Australian origin. Similar to cortado but stronger milk-to-espresso balance.</notes>
    </recipe>

  </milk_drink_recipes>

  <!-- ═══════════════════════════════════
       FILTER BREW RECIPES
  ═══════════════════════════════════ -->
  <filter_recipes>

    <recipe id="flt-001" name="Hario V60 — James Hoffman Method">
      <dose unit="g">15</dose>
      <water unit="g">250</water>
      <ratio>1:16.7</ratio>
      <grind>Medium-fine</grind>
      <temperature unit="celsius">93</temperature>
      <total_time>3:00–3:30</total_time>
      <steps>
        <step time="0:00">Rinse filter; add 15g coffee</step>
        <step time="0:00">Pour 50g bloom water; swirl gently</step>
        <step time="0:45">Continue to 150g in slow spiral pour</step>
        <step time="1:30">Continue to 250g total</step>
        <step time="3:00–3:30">Drawdown complete; flat coffee bed</step>
      </steps>
    </recipe>

    <recipe id="flt-002" name="Chemex — Standard Recipe">
      <dose unit="g">30</dose>
      <water unit="g">500</water>
      <ratio>1:16.7</ratio>
      <grind>Medium-coarse</grind>
      <temperature unit="celsius">93</temperature>
      <total_time>4:00–5:30</total_time>
      <steps>
        <step time="0:00">Pre-fold and rinse Chemex filter</step>
        <step time="0:00">Add 30g coffee</step>
        <step time="0:00">Bloom: 90g water; wait 45s</step>
        <step time="0:45">Pour to 180g</step>
        <step time="1:30">Pour to 320g</step>
        <step time="2:30">Pour to 500g total</step>
        <step time="4:30–5:30">Drawdown complete</step>
      </steps>
    </recipe>

    <recipe id="flt-003" name="French Press — Hoffman Long Steep">
      <dose unit="g">30</dose>
      <water unit="g">500</water>
      <ratio>1:16.7</ratio>
      <grind>Coarse</grind>
      <temperature unit="celsius">93</temperature>
      <total_time>9:00–10:00</total_time>
      <steps>
        <step time="0:00">Add coffee; pour all 500g water</step>
        <step time="4:00">Break crust; remove floating grounds</step>
        <step time="9:00">Slowly lower plunger just below surface</step>
        <step time="9:00">Pour immediately without pressing fully</step>
      </steps>
    </recipe>

    <recipe id="flt-004" name="AeroPress — Hoffman All-Rounder">
      <dose unit="g">11</dose>
      <water unit="g">200</water>
      <ratio>1:18</ratio>
      <grind>Medium-fine</grind>
      <temperature unit="celsius">90</temperature>
      <total_time>2:30</total_time>
      <steps>
        <step time="0:00">Standard orientation; wet filter; add coffee</step>
        <step time="0:00">Pour all 200g water</step>
        <step time="0:10">Stir 10× at top of chamber</step>
        <step time="0:15">Place cap and filter immediately</step>
        <step time="2:00">Flip; press slowly over 30 seconds</step>
        <step time="2:30">Stop at first hiss</step>
      </steps>
    </recipe>

    <recipe id="flt-005" name="Cold Brew Concentrate">
      <dose unit="g">100</dose>
      <water unit="g">800</water>
      <ratio>1:8</ratio>
      <grind>Extra coarse</grind>
      <temperature unit="celsius">4</temperature>
      <total_time>18–24 hours</total_time>
      <yield_notes>Dilute 1:1 to 1:3 before serving</yield_notes>
      <steps>
        <step>Combine coffee and cold water; stir</step>
        <step>Cover; refrigerate 18–24 hours</step>
        <step>Filter through mesh then paper filter</step>
        <step>Store sealed up to 14 days refrigerated</step>
      </steps>
    </recipe>

    <recipe id="flt-006" name="Moka Pot — Standard">
      <dose_note>Fill basket level; do not tamp</dose_note>
      <water_note>Fill to below safety valve; use pre-boiled water</water_note>
      <grind>Fine-medium</grind>
      <heat>Medium-low</heat>
      <total_time>5–8 minutes</total_time>
      <steps>
        <step>Fill bottom with pre-boiled water to valve</step>
        <step>Fill basket with coffee; level only</step>
        <step>Assemble; place on medium-low heat</step>
        <step>Remove before final gurgling rush</step>
        <step>Stir brewed coffee before pouring</step>
      </steps>
    </recipe>

    <recipe id="flt-007" name="Siphon — Standard">
      <dose unit="g">25</dose>
      <water unit="g">400</water>
      <ratio>1:16</ratio>
      <grind>Medium</grind>
      <temperature unit="celsius">92</temperature>
      <upper_chamber_steep unit="seconds">60–90</upper_chamber_steep>
      <steps>
        <step>Fill bottom chamber with 400g hot water</step>
        <step>Attach top chamber; apply heat</step>
        <step>Add coffee when water rises to top</step>
        <step>Stir gently; steep 60–90s</step>
        <step>Remove heat; wait for draw-down</step>
        <step>Serve immediately from lower chamber</step>
      </steps>
    </recipe>

    <recipe id="flt-008" name="Batch Brew — SCA Golden Cup">
      <dose unit="g_per_litre">65</dose>
      <water unit="g">1000</water>
      <ratio>1:15.4</ratio>
      <grind>Medium</grind>
      <temperature unit="celsius">93</temperature>
      <brew_time>4–6 minutes</brew_time>
      <hold_temperature unit="celsius">80–85</hold_temperature>
      <freshness_window>45 minutes in thermal carafe</freshness_window>
    </recipe>

  </filter_recipes>

