  <domain id="operations" label="Café Operations">
    <key_formulas>
      <formula id="beverage-cost-percent">
        <expression>(Total Ingredient Cost / Menu Price) × 100</expression>
        <target_percent>25–35%</target_percent>
      </formula>
      <formula id="gross-margin">
        <expression>((Menu Price - COGS) / Menu Price) × 100</expression>
      </formula>
      <formula id="labor-cost-percent">
        <expression>(Labor Cost / Revenue) × 100</expression>
        <target_percent>30–35%</target_percent>
      </formula>
      <formula id="inventory-turnover">
        <expression>COGS / Average Inventory Value</expression>
        <note>Higher = less waste; specialty coffee typically 2–4 weeks inventory cycle</note>
      </formula>
    </key_formulas>
  </domain>

