  <domain id="sensory" label="Sensory Analysis &amp; Cupping">
    <sca_cupping_protocol>
      <grind_ratio>8.25g per 150mL water</grind_ratio>
      <grind_size>Medium-coarse (consistent)</grind_size>
      <water_temp_c>93</water_temp_c>
      <steep_time_min>4</steep_time_min>
      <evaluation_steps>
        <step order="1">Dry fragrance (ground coffee aroma)</step>
        <step order="2">Wet aroma (after pour, first 4 min)</step>
        <step order="3">Break crust at 4 min, evaluate aroma</step>
        <step order="4">Clean cups at 8–10 min</step>
        <step order="5">Slurp and evaluate when ~70°C</step>
        <step order="6">Score at warm (~70°C) and cool (~40°C)</step>
      </evaluation_steps>
    </sca_cupping_protocol>

    <sca_score_form>
      <attribute name="Fragrance/Aroma" max_score="10"/>
      <attribute name="Flavor" max_score="10"/>
      <attribute name="Aftertaste" max_score="10"/>
      <attribute name="Acidity" max_score="10"/>
      <attribute name="Body" max_score="10"/>
      <attribute name="Balance" max_score="10"/>
      <attribute name="Uniformity" max_score="10"/>
      <attribute name="Clean Cup" max_score="10"/>
      <attribute name="Sweetness" max_score="10"/>
      <attribute name="Overall" max_score="10"/>
      <attribute name="Defects" max_score="-2 per taint, -4 per fault"/>
      <specialty_threshold>Score ≥ 80 points</specialty_threshold>
    </sca_score_form>

    <flavor_wheel_primary_categories>
