  <domain id="water" label="Water Science">
    <sca_recommended_water_profile>
      <parameter name="TDS" unit="mg/L" target="150" acceptable_range="75–250"/>
      <parameter name="Calcium Hardness" unit="mg/L as CaCO3" target="50–175"/>
      <parameter name="Total Alkalinity" unit="mg/L as CaCO3" target="40" acceptable_range="40–75"/>
      <parameter name="pH" target="7.0" acceptable_range="6.5–7.5"/>
      <parameter name="Sodium" unit="mg/L" max="10"/>
      <parameter name="Chlorine" unit="mg/L" target="0"/>
    </sca_recommended_water_profile>

    <minerals>
      <mineral name="Magnesium (Mg²⁺)">
        <role>Enhances extraction efficiency; improves flavor clarity and brightness</role>
        <optimal_mg_per_L>10–30</optimal_mg_per_L>
      </mineral>
      <mineral name="Calcium (Ca²⁺)">
        <role>Contributes to hardness; aids extraction but can cause scale</role>
        <optimal_mg_per_L>40–80</optimal_mg_per_L>
      </mineral>
      <mineral name="Bicarbonate (HCO₃⁻)">
        <role>Buffer — neutralizes acids; too high = flat coffee; too low = sour</role>
        <optimal_mg_per_L>40–80</optimal_mg_per_L>
      </mineral>
      <mineral name="Sodium (Na⁺)">
        <role>Enhances sweetness perception in small amounts; tastes salty if high</role>
        <optimal_mg_per_L>0–10</optimal_mg_per_L>
      </mineral>
    </minerals>
  </domain>

  <!-- ═══════════════════════════════════════════════
       DOMAIN 6: ROASTING SCIENCE
  ═══════════════════════════════════════════════ -->
  <domain id="roasting" label="Roasting Science">
    <roast_stages>
      <stage order="1" name="Drying Phase">
        <temp_range_c>100–160</temp_range_c>
        <description>Moisture evaporation (green bean ~10–12% moisture → ~1–2%)</description>
      </stage>
      <stage order="2" name="Maillard Reaction Phase">
        <temp_range_c>150–200</temp_range_c>
        <description>Amino acids + reducing sugars → complex aroma compounds, brown color</description>
      </stage>
      <stage order="3" name="First Crack">
        <temp_range_c>196–205</temp_range_c>
        <description>Steam + CO₂ build-up causes audible crack. Light roasts finish here.</description>
      </stage>
      <stage order="4" name="Development Phase">
        <temp_range_c>205–220</temp_range_c>
        <description>Critical flavor development. DTR (Development Time Ratio) = time after 1st crack / total roast time. Target: 20–25%.</description>
      </stage>
      <stage order="5" name="Second Crack">
        <temp_range_c>224–230</temp_range_c>
        <description>CO₂ release, oily surface. Dark roasts. Caramelization dominant.</description>
      </stage>
    </roast_stages>

    <roast_levels>
      <level name="Light" agtron="~75–95" temp_finish_c="196–205" notes="Origin flavors preserved; high acidity"/>
      <level name="Medium-Light" agtron="~65–75" temp_finish_c="205–210" notes="Balanced; some roast character"/>
      <level name="Medium" agtron="~55–65" temp_finish_c="210–220" notes="Classic balance; caramel, nuts"/>
      <level name="Medium-Dark" agtron="~45–55" temp_finish_c="220–225" notes="Bittersweet, lower acidity"/>
      <level name="Dark" agtron="~25–45" temp_finish_c="225–240" notes="Roast dominates; smoky, bold"/>
    </roast_levels>
  </domain>

