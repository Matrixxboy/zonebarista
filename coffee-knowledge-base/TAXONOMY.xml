  <domain id="brewing" label="Brewing Methods &amp; Science">
    <method id="pour-over" file="brewing-methods/pour-over.md">
      <label>Pour Over</label>
      <equipment>Hario V60, Chemex, Kalita Wave, Origami</equipment>
      <typical_ratio>1:15 to 1:17 (coffee:water by weight)</typical_ratio>
      <grind>Medium-fine (V60), Medium (Chemex)</grind>
      <temperature_c>90–96</temperature_c>
      <brew_time_min>2.5–4</brew_time_min>
      <technique>Bloom 2× coffee weight for 30–45s, then pour in pulses or continuous spiral</technique>
    </method>

    <method id="french-press" file="brewing-methods/french-press.md">
      <label>French Press</label>
      <brew_type>Full immersion</brew_type>
      <typical_ratio>1:15 to 1:17</typical_ratio>
      <grind>Coarse</grind>
      <temperature_c>90–96</temperature_c>
      <brew_time_min>4</brew_time_min>
    </method>

    <method id="aeropress" file="brewing-methods/aeropress.md">
      <label>AeroPress</label>
      <brew_type>Hybrid pressure + immersion</brew_type>
      <typical_ratio>1:6 to 1:15 (highly variable)</typical_ratio>
      <grind>Fine to medium</grind>
      <temperature_c>80–96</temperature_c>
      <brew_time_min>1–3</brew_time_min>
      <techniques>Standard, Inverted, Fellow Prismo method</techniques>
    </method>

    <method id="cold-brew" file="brewing-methods/cold-brew.md">
      <label>Cold Brew</label>
      <brew_type>Cold immersion</brew_type>
      <typical_ratio>1:8 (concentrate) to 1:15 (ready-to-drink)</typical_ratio>
      <grind>Coarse</grind>
      <temperature_c>4–20</temperature_c>
      <brew_time_hours>12–24</brew_time_hours>
    </method>

    <method id="moka-pot" file="brewing-methods/moka-pot.md">
      <label>Moka Pot</label>
      <brew_type>Stovetop pressure percolation (~1.5 bar)</brew_type>
      <grind>Fine-medium</grind>
      <temperature_c>Boiling water in chamber ~92–96</temperature_c>
    </method>

    <method id="siphon" file="brewing-methods/siphon.md">
      <label>Siphon (Vacuum Pot)</label>
      <brew_type>Vapor pressure + immersion</brew_type>
      <grind>Medium</grind>
      <temperature_c>90–93</temperature_c>
      <brew_time_min>1–2</brew_time_min>
    </method>
  </domain>

