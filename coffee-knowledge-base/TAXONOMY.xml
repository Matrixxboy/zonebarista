  <domain id="espresso" label="Espresso Science &amp; Extraction Engineering">
    <topic id="extraction-theory" file="espresso/extraction-theory.md">
      <label>Extraction Theory</label>
      <key_variables>
        <variable name="Dose" unit="g" typical_range="14–22g"/>
        <variable name="Yield" unit="g" typical_range="25–50g"/>
        <variable name="Brew Ratio" unit="ratio" typical_range="1:1.5 to 1:3"/>
        <variable name="Extraction Time" unit="seconds" typical_range="25–35s"/>
        <variable name="Extraction Yield" unit="%" optimal_range="18–22%"/>
        <variable name="TDS" unit="%" espresso_range="8–12%"/>
        <variable name="Pressure" unit="bar" typical="9 bar"/>
        <variable name="Temperature" unit="°C" typical_range="90–96°C"/>
      </key_variables>
      <formulas>
        <formula id="brew-ratio">Yield / Dose</formula>
        <formula id="extraction-yield">(TDS × Beverage Mass) / Dry Coffee Mass × 100</formula>
      </formulas>
    </topic>

    <topic id="pressure-profiling" file="espresso/pressure-flow-profiling.md">
      <label>Pressure &amp; Flow Profiling</label>
      <concepts>
        <concept>Pre-infusion (low pressure soak: 2–4 bar)</concept>
        <concept>Ramp to 9 bar extraction</concept>
        <concept>Declining pressure profile (9→6 bar)</concept>
        <concept>Turbo shots (high flow, fast extraction)</concept>
        <concept>Blooming (AeroPress-style in espresso)</concept>
      </concepts>
    </topic>

    <topic id="puck-preparation" file="espresso/puck-preparation.md">
      <label>Puck Preparation</label>
      <steps>
        <step order="1">Dose (weigh into portafilter)</step>
        <step order="2">Distribute (WDT tool or Stockfleth)</step>
        <step order="3">Level</step>
        <step order="4">Tamp (15–20 kg force, level)</step>
        <step order="5">Insert portafilter and brew</step>
      </steps>
    </topic>

    <topic id="shot-diagnosis" file="espresso/shot-diagnosis.md">
      <label>Shot Diagnosis</label>
      <defects>
        <defect id="under-extraction">
          <symptoms>Sour, thin, fast shot, pale crema</symptoms>
          <causes>Too coarse, too low dose, too hot water, short time</causes>
          <fixes>Grind finer, increase dose, lower temperature</fixes>
        </defect>
        <defect id="over-extraction">
          <symptoms>Bitter, dry, harsh, dark crema</symptoms>
          <causes>Too fine, too long, too high temperature</causes>
          <fixes>Grind coarser, reduce time, lower temp</fixes>
        </defect>
        <defect id="channeling">
          <symptoms>Uneven flow, blonde early, streaky puck</symptoms>
          <causes>Poor distribution, uneven tamp, cracked puck</causes>
          <fixes>WDT tool, even tamp, proper dosing</fixes>
        </defect>
      </defects>
    </topic>
  </domain>

  <!-- ═══════════════════════════════════════════════
       DOMAIN 4: BREWING METHODS
